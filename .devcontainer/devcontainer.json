{
  "name": "python-template",
  "build": {
    "context": "..",
    "dockerfile": "Containerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=python_template-data,target=/data,type=volume"
  ],
  "remoteUser": "vscode",
  "runArgs": [
    "--userns=keep-id"
  ],
  "containerEnv": {
    "UV_LINK_MODE": "copy",
    "HOME": "/home/vscode"
  },
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "tamasfe.even-better-toml",
        "ms-toolsai.jupyter",
        "redhat.vscode-yaml",
        "ryanluker.vscode-coverage-gutters",
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "DavidWang.ini-for-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "files.associations": {
          ".pypirc*": "ini"
        }
      }
    }
  },
  "postCreateCommand": "uv python install && uv sync --all-extras --frozen && bash .devcontainer/initialize.sh && uv run pre-commit install"
}
